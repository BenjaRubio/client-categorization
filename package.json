{
  "name": "client-categorization",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "classify:pendings": "tsx src/services/classification/classify-pendings.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "seed:if-empty": "tsx src/db/seed/seed-if-empty.ts",
    "postdeploy:jobs": "npm run classify:pendings",
    "vercel-build": "prisma generate && prisma migrate deploy && npm run seed:if-empty && next build"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "papaparse": "^5.5.3",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "schema": "src/db/prisma/schema.prisma",
    "seed": "tsx src/db/seed/index.ts"
  }
}
