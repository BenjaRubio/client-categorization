#
# Production (Vercel + Supabase)
# Configure these values in Vercel Project Settings -> Environment Variables.
#

# Connection pooling URL (recommended for runtime queries)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct database URL (required for Prisma migrations)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres"

# LLM providers (set only the one(s) you use)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
